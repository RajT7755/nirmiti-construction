# Backend API URL (run server from main branch: npm run server:dev)
VITE_API_URL=http://localhost:3001
# Set to true to load data from backend API instead of local state
VITE_USE_API=false
# Phase 2: data persists in localStorage (nirmiti_cms_store_v1). Set false after migration.
# VITE_DESIGN_PREVIEW=false

# Shared API key (sent as X-API-Key + Authorization Bearer when set)
# VITE_API_KEY=

# Inventory payments / PO / Work Order API key (falls back to VITE_API_KEY)
# Used by: supplierPayments, contractorPayments, purchaseOrderPayments, workOrderPayments
# VITE_INVENTORY_API_KEY=

# WhatsApp Business Cloud API (server-side — Phase 2 backend)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

